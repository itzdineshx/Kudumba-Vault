  "solidity": "// SPDX-License-Identifier: MIT\n// Deployed on Ethereum Sepolia Testnet\npragma solidity ^0.8.19;\n\ncontract KudumbaVault {\n    struct Document {\n        bool exists;\n        address owner;\n        string name;\n        string category;\n        uint256 timestamp;\n        mapping(address => bool) accessList;\n        mapping(address => uint256) accessExpiry;\n    }\n\n    mapping(bytes32 => Document) private documents;\n    mapping(address => bytes32[]) private ownerDocuments;\n\n    address public admin;\n\n    event DocumentRegistered(\n        bytes32 indexed docHash,\n        address indexed owner,\n        string name,\n        string category,\n        uint256 timestamp\n    );\n\n    event DocumentVerified(\n        bytes32 indexed docHash,\n        address indexed verifier,\n        bool isValid,\n        uint256 timestamp\n    );\n\n    event AccessGranted(\n        bytes32 indexed docHash,\n        address indexed owner,\n        address indexed sharedWith,\n        uint256 expiresAt\n    );\n\n    event AccessRevoked(\n        bytes32 indexed docHash,\n        address indexed owner,\n        address indexed revokedFrom\n    );\n\n    constructor() {\n        admin = msg.sender;\n    }\n\n    modifier onlyDocOwner(bytes32 docHash) {\n        require(documents[docHash].exists, \"Document not found\");\n        require(documents[docHash].owner == msg.sender, \"Not document owner\");\n        _;\n    }\n\n    function registerDocument(\n        bytes32 docHash,\n        string calldata name,\n        string calldata category\n    ) external {\n        require(!documents[docHash].exists, \"Document already registered\");\n        \n        Document storage doc = documents[docHash];\n        doc.exists = true;\n        doc.owner = msg.sender;\n        doc.name = name;\n        doc.category = category;\n        doc.timestamp = block.timestamp;\n        \n        ownerDocuments[msg.sender].push(docHash);\n        \n        emit DocumentRegistered(docHash, msg.sender, name, category, block.timestamp);\n    }\n\n    function verifyDocument(bytes32 docHash) external view returns (\n        bool exists,\n        address owner,\n        string memory name,\n        string memory category,\n        uint256 timestamp\n    ) {\n        Document storage doc = documents[docHash];\n        return (doc.exists, doc.owner, doc.name, doc.category, doc.timestamp);\n    }\n\n    function grantAccess(\n        bytes32 docHash,\n        address member,\n        uint256 expiresAt\n    ) external onlyDocOwner(docHash) {\n        documents[docHash].accessList[member] = true;\n        documents[docHash].accessExpiry[member] = expiresAt;\n        \n        emit AccessGranted(docHash, msg.sender, member, expiresAt);\n    }\n\n    function revokeAccess(\n        bytes32 docHash,\n        address member\n    ) external onlyDocOwner(docHash) {\n        documents[docHash].accessList[member] = false;\n        documents[docHash].accessExpiry[member] = 0;\n        \n        emit AccessRevoked(docHash, msg.sender, member);\n    }\n\n    function hasAccess(\n        bytes32 docHash,\n        address member\n    ) external view returns (bool) {\n        Document storage doc = documents[docHash];\n        if (!doc.exists) return false;\n        if (doc.owner == member) return true;\n        if (!doc.accessList[member]) return false;\n        if (doc.accessExpiry[member] != 0 && doc.accessExpiry[member] < block.timestamp) return false;\n        return true;\n    }\n\n    function getDocumentCount(address owner) external view returns (uint256) {\n        return ownerDocuments[owner].length;\n    }\n\n    function getDocumentHashByIndex(address owner, uint256 index) external view returns (bytes32) {\n        require(index < ownerDocuments[owner].length, \"Index out of bounds\");\n        return ownerDocuments[owner][index];\n    }\n}"
}
