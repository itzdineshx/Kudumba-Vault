contract KudumbaVault {
    struct Document {
        bool exists;
        address owner;
        string name;
        string category;
        uint256 timestamp;
        mapping(address => bool) accessList;
        mapping(address => uint256) accessExpiry;
    }

    mapping(bytes32 => Document) private documents;
    mapping(address => bytes32[]) private ownerDocuments;

    address public admin;

    event DocumentRegistered(
        bytes32 indexed docHash,
        address indexed owner,
        string name,
        string category,
        uint256 timestamp
    );

    event DocumentVerified(
        bytes32 indexed docHash,
        address indexed verifier,
        bool isValid,
        uint256 timestamp
    );

    event AccessGranted(
        bytes32 indexed docHash,
        address indexed owner,
        address indexed sharedWith,
        uint256 expiresAt
    );

    event AccessRevoked(
        bytes32 indexed docHash,
        address indexed owner,
        address indexed revokedFrom
    );

    constructor() {
        admin = msg.sender;
    }

    modifier onlyDocOwner(bytes32 docHash) {
        require(documents[docHash].exists, "Document not found");
        require(documents[docHash].owner == msg.sender, "Not document owner");
        _;
    }

    function registerDocument(
        bytes32 docHash,
        string calldata name,
        string calldata category
    ) external {
        require(!documents[docHash].exists, "Document already registered");

        Document storage doc = documents[docHash];
        doc.exists = true;
        doc.owner = msg.sender;
        doc.name = name;
        doc.category = category;
        doc.timestamp = block.timestamp;

        ownerDocuments[msg.sender].push(docHash);

        emit DocumentRegistered(docHash, msg.sender, name, category, block.timestamp);
    }

    function verifyDocument(bytes32 docHash) external view returns (
        bool exists,
        address owner,
        string memory name,
        string memory category,
        uint256 timestamp
    ) {
        Document storage doc = documents[docHash];
        return (doc.exists, doc.owner, doc.name, doc.category, doc.timestamp);
    }

    function grantAccess(
        bytes32 docHash,
        address member,
        uint256 expiresAt
    ) external onlyDocOwner(docHash) {
        documents[docHash].accessList[member] = true;
        documents[docHash].accessExpiry[member] = expiresAt;

        emit AccessGranted(docHash, msg.sender, member, expiresAt);
    }

    function revokeAccess(
        bytes32 docHash,
        address member
    ) external onlyDocOwner(docHash) {
        documents[docHash].accessList[member] = false;
        documents[docHash].accessExpiry[member] = 0;

        emit AccessRevoked(docHash, msg.sender, member);
    }

    function hasAccess(
        bytes32 docHash,
        address member
    ) external view returns (bool) {
        Document storage doc = documents[docHash];
        if (!doc.exists) return false;
        if (doc.owner == member) return true;
        if (!doc.accessList[member]) return false;
        if (doc.accessExpiry[member] != 0 && doc.accessExpiry[member] < block.timestamp) return false;
        return true;
    }

    function getDocumentCount(address owner) external view returns (uint256) {
        return ownerDocuments[owner].length;
    }

    function getDocumentHashByIndex(address owner, uint256 index) external view returns (bytes32) {
        require(index < ownerDocuments[owner].length, "Index out of bounds");
        return ownerDocuments[owner][index];
    }
}
